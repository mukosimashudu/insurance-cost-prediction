# Ignore Python cache and compiled files
__pycache__/
*.pyc
*.pyo
*.pyd

# Ignore virtual environments
.env
.venv
env/
venv/

# Ignore OS-specific files
.DS_Store
Thumbs.db

# Ignore logs and temporary files
*.log
*.tmp
*.swp

# Ignore Jupyter notebook checkpoints
.ipynb_checkpoints/

# Ignore build and package directories
build/
dist/
*.egg-info/

# Ignore Streamlit temporary files
.streamlit/

# DO NOT ignore Models/ or Dataset/ so they are uploaded
# (remove any lines like "Models/" or "*.pkl" if they exist)
